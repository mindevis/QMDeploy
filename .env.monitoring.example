# Скопируйте в .env.monitoring и подставьте значения.
# Формат MySQL DSN для mysqld-exporter: user:password@tcp(host:3306)/
MONITORING_MYSQL_DSN=user:password@tcp(127.0.0.1:3306)/

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ROOT_URL=http://localhost:3030

# Опционально: плагины Grafana через запятую
# GRAFANA_INSTALL_PLUGINS=grafana-clock-panel
